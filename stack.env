# Portainer / Docker Compose environment defaults for the pull-only deployment.
# Copy to `.env` for local `docker compose` usage, or paste the same key/value
# pairs into the Portainer stack environment variables UI.

VBOGS_TORCH_IMAGE=oakleyth/vbogs-torch@sha256:3c33e88a1772434e7c67b52838a6a379b08d283612763d0263f72c939a361ccb
VBOGS_JAX_IMAGE=oakleyth/vbogs-jax@sha256:f1a9774315e25757e84ef0ebcf27a54d8a761ac161d99a408130cae6325cea3a
# Keep the lightweight orchestration image tag-based so Portainer can pull the
# latest runner changes after publishing without rebuilding the Torch/JAX images.
VBOGS_PIPELINE_IMAGE=oakleyth/vbogs-pipeline:latest

# KITTI-360 drive id.
VBOGS_DRIVE=2013_05_28_drive_0007_sync

# Pipeline runner defaults. Keep autorun off for the first stack deploy.
VBOGS_PIPELINE_AUTORUN=0
VBOGS_PIPELINE_CONFIG=pipeline_config.portainer.yaml
#VBOGS_PIPELINE_ARGS=

# Optional Google Drive upload after a successful autorun. The pipeline image
# uses rclone and uploads the curated zip at outputs/v1_0/<drive>.zip.
# Share the private Drive folder with the service-account email, then set the
# folder id and credentials below in Portainer's environment UI.
VBOGS_GDRIVE_UPLOAD=0
VBOGS_GDRIVE_REMOTE=vbogs_gdrive
VBOGS_GDRIVE_DEST=
#VBOGS_GDRIVE_FOLDER_ID=
#VBOGS_GDRIVE_SERVICE_ACCOUNT_CREDENTIALS={"type":"service_account",...}
#VBOGS_GDRIVE_SERVICE_ACCOUNT_FILE=/run/secrets/vbogs-google-drive-service-account.json
#VBOGS_GDRIVE_DRY_RUN=1

# Optional SSH/SFTP download sidecar. Paste one public key line, not your
# private key. Leaving this unset keeps the service idle.
#VBOGS_TRANSFER_HOST_PORT=22022
#VBOGS_TRANSFER_AUTHORIZED_KEYS=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... you@example

# Example full v1.0 run after the idle stack is healthy:
VBOGS_PIPELINE_AUTORUN=1
VBOGS_PIPELINE_ARGS=--gpu 0 --jax-device 0 --start-at prepare --stop-after bundle
