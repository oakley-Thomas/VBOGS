# Portainer / Docker Compose environment defaults for the pull-only deployment.
# Copy to `.env` for local `docker compose` usage, or paste the same key/value
# pairs into the Portainer stack environment variables UI.

VBOGS_TORCH_IMAGE=oakleyth/vbogs-torch@sha256:3c33e88a1772434e7c67b52838a6a379b08d283612763d0263f72c939a361ccb
VBOGS_JAX_IMAGE=oakleyth/vbogs-jax@sha256:f1a9774315e25757e84ef0ebcf27a54d8a761ac161d99a408130cae6325cea3a
VBOGS_PIPELINE_IMAGE=oakleyth/vbogs-pipeline@sha256:7280de9be3fc049fbe5713fd31b941c17ffee9e534343a3c7ed48cafbe82f388

# KITTI-360 drive id.
VBOGS_DRIVE=2013_05_28_drive_0007_sync

# Pipeline runner defaults. Keep autorun off for the first stack deploy.
VBOGS_PIPELINE_AUTORUN=0
VBOGS_PIPELINE_CONFIG=pipeline_config.portainer.yaml
#VBOGS_PIPELINE_ARGS=

# Example full v1.0 run after the idle stack is healthy:
VBOGS_PIPELINE_AUTORUN=1
VBOGS_PIPELINE_ARGS=--gpu 0 --jax-device 0 --start-at prepare --stop-after bundle
